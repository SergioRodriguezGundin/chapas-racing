# Supabase — copia a `.env.local` y sustituye con credenciales de tu proyecto.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

# URL del proyecto (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clave pública anon (anon / publishable key — segura en cliente con RLS activo)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Google OAuth — NO va en .env.local
# ---------------------------------------------------------------------------
# El login con Google se configura en Supabase Dashboard, no con variables de
# entorno de este repo:
#   Authentication → Providers → Google → Client ID + Client Secret
#   Authentication → URL Configuration → Redirect URLs (p. ej. http://localhost:3000/auth/callback)
#
# Guía: docs/setup-google-oauth.md  |  En la app: /docs/setup-google-oauth
# Proyecto de referencia: tiwagdlcxnzfjnncqsrf
